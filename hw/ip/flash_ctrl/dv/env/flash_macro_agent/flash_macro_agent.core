name: "lowrisc:dv:flash_macro_agent:0.1"
description: "Flash Macro DV UVM agent"
filesets:
  files_dv:
    depend:
      - lowrisc:dv:dv_utils
      - lowrisc:dv:dv_lib
      - lowrisc:virtual_ip:flash_phy_macro_pkg
    files:
      - flash_macro_if.sv
      - flash_macro_agent_pkg.sv
      - flash_macro_item.sv: {is_include_file: true}
      - flash_macro_agent_cfg.sv: {is_include_file: true}
      - flash_macro_agent_cov.sv: {is_include_file: true}
      - flash_macro_driver.sv: {is_include_file: true}
      - flash_macro_monitor.sv: {is_include_file: true}
      - flash_macro_agent.sv: {is_include_file: true}
      - seq_lib/flash_macro_base_seq.sv: {is_include_file: true}
      - seq_lib/flash_macro_seq_list.sv: {is_include_file: true}
    file_type: systemVerilogSource

targets:
  default:
    filesets:
      - files_dv
